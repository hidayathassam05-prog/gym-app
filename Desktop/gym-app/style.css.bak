* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

body {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #2d3748;
  min-height: 100vh;
}

/* SCREENS */
.screen {
  display: none;
}

.screen.active {
  display: block;
}

#dashboardScreen.active {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background: #f7fafc;
}

/* AUTH SCREEN - FULL SCREEN CENTERED */
#authScreen {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  width: 100%;
  padding: 20px;
}

#authScreen.active {
  display: flex;
}

/* AUTH SCREEN */
.auth-container {
  max-width: 450px;
  width: 100%;
  background: white;
  padding: 50px 40px;
  border-radius: 16px;
  box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
  animation: slideUp 0.5s ease-out;
}

@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(30px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.gym-logo {
  text-align: center;
  font-size: 48px;
  margin-bottom: 15px;
  animation: bounce 2s infinite;
}

@keyframes bounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-8px); }
}

.auth-container h1 {
  font-size: 32px;
  margin-bottom: 8px;
  color: #2d3748;
  font-weight: 700;
  text-align: center;
}

.subtitle {
  color: #718096;
  margin-bottom: 35px;
  font-size: 14px;
  text-align: center;
  font-weight: 500;
}

.tabs {
  display: flex;
  gap: 12px;
  margin-bottom: 30px;
  background: #f7fafc;
  padding: 4px;
  border-radius: 10px;
}

.tab-btn {
  flex: 1;
  padding: 12px 16px;
  background: transparent;
  border: none;
  border-radius: 8px;
  cursor: pointer;
  font-weight: 600;
  color: #718096;
  transition: all 0.3s ease;
  font-size: 14px;
}

.tab-btn:hover {
  color: #2d3748;
  background: #edf2f7;
}

.tab-btn.active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  box-shadow: 0 4px 12px rgba(102, 126, 234, 0.4);
}

.tab-content {
  display: none;
}

.tab-content.active {
  display: block;
}

/* INPUTS & BUTTONS */
.input {
  width: 100%;
  padding: 13px 16px;
  margin-bottom: 14px;
  border: 2px solid #e2e8f0;
  border-radius: 10px;
  font-size: 14px;
  transition: all 0.3s ease;
  background: white;
  font-family: inherit;
}

.input:focus {
  outline: none;
  border-color: #667eea;
  box-shadow: 0 0 0 4px rgba(102, 126, 234, 0.1);
  background: white;
}

.input::placeholder {
  color: #a0aec0;
}

.btn {
  width: 100%;
  padding: 13px 16px;
  border: none;
  border-radius: 10px;
  font-size: 15px;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.3s ease;
  margin-bottom: 12px;
  text-transform: none;
  letter-spacing: 0.5px;
}

.btn-primary {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  box-shadow: 0 4px 15px rgba(102, 126, 234, 0.4);
}

.btn-primary:hover {
  transform: translateY(-2px);
  box-shadow: 0 6px 20px rgba(102, 126, 234, 0.6);
}

.btn-primary:active {
  transform: translateY(0);
}

.btn-danger {
  background: linear-gradient(135deg, #f56565 0%, #e53e3e 100%);
  color: white;
  width: auto;
  padding: 10px 24px;
  margin-top: 20px;
  box-shadow: 0 4px 15px rgba(245, 101, 101, 0.3);
}

.btn-danger:hover {
  transform: translateY(-2px);
  box-shadow: 0 6px 20px rgba(245, 101, 101, 0.4);
}

/* NAVBAR */
.navbar {
  background: white;
  padding: 16px 30px;
  box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: 2px solid #f0f4f8;
}

.navbar-brand {
  display: flex;
  align-items: center;
  gap: 12px;
}

.gym-logo-small {
  font-size: 28px;
}

.navbar h2 {
  color: #2d3748;
  font-size: 24px;
  font-weight: 700;
}

.nav-buttons {
  display: flex;
  gap: 20px;
}

.nav-btn {
  padding: 10px 16px;
  background: none;
  border: none;
  color: #718096;
  cursor: pointer;
  font-weight: 600;
  transition: all 0.3s ease;
  border-bottom: 3px solid transparent;
  font-size: 14px;
}

.nav-btn:hover {
  color: #667eea;
  border-bottom-color: #667eea;
}

.logout-btn {
  color: #f56565;
}

.logout-btn:hover {
  color: #e53e3e;
  border-bottom-color: #e53e3e;
}

/* SECTIONS - ONLY ONE VISIBLE AT A TIME */
.section {
  display: none;
  min-height: calc(100vh - 70px);
  background: #f7fafc;
  overflow-y: auto;
}

.section.active {
  display: block;
}

.container {
  max-width: 1000px;
  margin: 0 auto;
  padding: 40px 20px;
}

/* STATS GRID */
.stats-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  gap: 20px;
  margin: 30px 0;
}

.stat-card {
  background: white;
  padding: 25px;
  border-radius: 12px;
  box-shadow: 0 2px 12px rgba(0, 0, 0, 0.06);
  text-align: center;
  border-left: 4px solid #667eea;
  transition: all 0.3s ease;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-card:hover {
  transform: translateY(-6px);
  box-shadow: 0 12px 24px rgba(102, 126, 234, 0.15);
}

.stat-card .stat-icon {
  margin-bottom: 12px;
}

.stat-card h3 {
  font-size: 32px;
  color: #667eea;
  margin-bottom: 8px;
  font-weight: 700;
}

.stat-card p {
  color: #718096;
  font-size: 14px;
  font-weight: 500;
}

/* WORKOUT FORM */
.workout-form {
  background: white;
  padding: 25px;
  border-radius: 12px;
  box-shadow: 0 2px 12px rgba(0, 0, 0, 0.06);
  margin-bottom: 30px;
  border-top: 4px solid #667eea;
}

.workout-form select,
.workout-form input {
  margin-bottom: 15px;
}

.recent-workouts {
  margin-top: 40px;
}

.recent-workouts .section-header {
  margin-bottom: 20px;
}

/* WORKOUT LIST */
.workout-list {
  display: grid;
  gap: 15px;
}

.workout-item {
  background: white;
  padding: 20px;
  border-radius: 10px;
  box-shadow: 0 2px 12px rgba(0, 0, 0, 0.06);
  border-left: 4px solid #667eea;
  display: flex;
  justify-content: space-between;
  align-items: center;
  transition: all 0.3s ease;
}

.workout-item:hover {
  box-shadow: 0 6px 16px rgba(0, 0, 0, 0.1);
  transform: translateY(-2px);
}

.workout-details h4 {
  margin-bottom: 8px;
  color: #2d3748;
  font-weight: 600;
}

.workout-details p {
  color: #718096;
  font-size: 13px;
}

.delete-btn {
  background: #fee2e2;
  color: #f56565;
  border: none;
  padding: 8px 12px;
  border-radius: 6px;
  cursor: pointer;
  font-size: 12px;
  font-weight: 600;
  transition: all 0.3s ease;
}

.delete-btn:hover {
  background: #fc8181;
  color: white;
}

.empty-message {
  text-align: center;
  color: #a0aec0;
  padding: 40px 20px;
  font-size: 15px;
}

/* PROFILE CARD */
.profile-card {
  background: white;
  padding: 30px;
  border-radius: 12px;
  box-shadow: 0 2px 12px rgba(0, 0, 0, 0.06);
}

.profile-info {
  margin-bottom: 30px;
  border-bottom: 2px solid #f0f4f8;
  padding-bottom: 20px;
}

.profile-info p {
  margin-bottom: 15px;
  font-size: 16px;
  color: #2d3748;
}

.profile-info strong {
  color: #667eea;
}

.stats-summary {
  background: linear-gradient(135deg, #f7fafc 0%, #edf2f7 100%);
  padding: 20px;
  border-radius: 10px;
  margin-bottom: 20px;
  border-left: 4px solid #667eea;
}

.stats-summary h3 {
  margin-bottom: 15px;
  color: #667eea;
  font-weight: 600;
}

.stats-summary p {
  margin-bottom: 10px;
  font-size: 15px;
  color: #2d3748;
}

/* CARD COMPONENT */
.card {
  background: white;
  padding: 25px;
  border-radius: 12px;
  box-shadow: 0 2px 12px rgba(0, 0, 0, 0.06);
  border-top: 4px solid #667eea;
  margin-bottom: 30px;
  transition: all 0.3s ease;
}

.card:hover {
  box-shadow: 0 8px 20px rgba(102, 126, 234, 0.15);
}

.card h3 {
  margin-bottom: 20px;
  color: #2d3748;
  font-weight: 600;
  font-size: 18px;
}

/* WATER TRACKER */
.water-tracker {
  padding: 20px;
}

.water-progress-container {
  text-align: center;
}

.water-progress-bar {
  width: 100%;
  height: 30px;
  background: #f0f4f8;
  border-radius: 15px;
  overflow: hidden;
  margin-bottom: 15px;
  box-shadow: inset 0 2px 4px rgba(0, 0, 0, 0.06);
}

.water-progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #667eea, #764ba2);
  width: 0%;
  transition: width 0.5s ease;
}

.water-progress-container p {
  margin: 10px 0;
  font-size: 14px;
  color: #718096;
}

.water-progress-container p:first-of-type {
  font-weight: 600;
  color: #667eea;
}

/* GOALS LIST */
.goals-list {
  display: grid;
  gap: 15px;
}

.goal-item {
  background: white;
  padding: 20px;
  border-radius: 10px;
  box-shadow: 0 2px 12px rgba(0, 0, 0, 0.06);
  border-left: 4px solid #667eea;
  display: flex;
  justify-content: space-between;
  align-items: center;
  transition: all 0.3s ease;
}

.goal-item:hover {
  box-shadow: 0 6px 16px rgba(0, 0, 0, 0.1);
  transform: translateY(-2px);
}

.goal-item.completed {
  border-left-color: #48bb78;
  opacity: 0.8;
  background: #f0fff4;
}

.goal-details h4 {
  margin-bottom: 8px;
  color: #2d3748;
  font-weight: 600;
}

.goal-details p {
  color: #718096;
  font-size: 13px;
  margin-bottom: 5px;
}

.goal-actions {
  display: flex;
  gap: 10px;
  align-items: center;
}

.goal-btn {
  background: #dbeafe;
  color: #667eea;
  border: none;
  padding: 8px 12px;
  border-radius: 6px;
  cursor: pointer;
  font-size: 14px;
  font-weight: 600;
  transition: all 0.3s ease;
}

.goal-btn:hover {
  background: #bfdbfe;
  color: #764ba2;
  transform: translateY(-1px);
}

/* MEASUREMENTS */
.measurement-group {
  background: #f7fafc;
  padding: 15px;
  border-radius: 8px;
  margin-bottom: 15px;
  border-left: 4px solid #667eea;
}

.measurement-group h4 {
  color: #2d3748;
  margin-bottom: 10px;
  font-weight: 600;
}

.measurement-row {
  display: flex;
  justify-content: space-between;
  padding: 8px 0;
  border-bottom: 1px solid #f0f4f8;
}

.measurement-row:last-child {
  border-bottom: none;
}

.measurement-row span:first-child {
  font-weight: 600;
  color: #667eea;
}

.measurement-row span:last-child {
  color: #718096;
}

/* QUICK ACCESS & BUTTON GRID */
.quick-access {
  background: white;
  padding: 30px;
  border-radius: 12px;
  box-shadow: 0 2px 12px rgba(0, 0, 0, 0.06);
  border-top: 4px solid #667eea;
}

.quick-access h3 {
  margin-bottom: 20px;
  color: #2d3748;
  font-size: 18px;
  font-weight: 600;
}

.button-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  gap: 15px;
}

.button-grid .btn {
  padding: 16px 20px;
  text-align: center;
  border-radius: 10px;
  font-weight: 600;
  transition: all 0.3s ease;
  cursor: pointer;
  border: none;
}

.button-grid .btn-secondary {
  background: #f0f4f8;
  color: #667eea;
  border: 2px solid #667eea;
}

.button-grid .btn-secondary:hover {
  background: #667eea;
  color: white;
  transform: translateY(-2px);
  box-shadow: 0 6px 16px rgba(102, 126, 234, 0.3);
}

/* TRAINER RECENT LIST */
#trainerRecentList {
  margin-top: 20px;
}
  .nav-buttons {
    flex-wrap: wrap;
    gap: 10px;
  }

  .stats-grid {
    grid-template-columns: repeat(2, 1fr);
  }

  .auth-container {
    margin: 40px 20px;
    padding: 30px 20px;
  }

  .form-grid {
    grid-template-columns: 1fr;
  }

  .quick-actions {
    flex-direction: column;
  }
}

@media (max-width: 768px) {
  .container {
    padding: 30px 15px;
  }

  .navbar {
    flex-direction: column;
    gap: 15px;
  }

  .nav-buttons {
    flex-wrap: wrap;
  }

  .stats-grid {
    grid-template-columns: repeat(2, 1fr);
  }

  .form-grid {
    grid-template-columns: 1fr;
  }

  .section-header {
    flex-direction: column;
    align-items: flex-start;
  }
}

/* SECTION HEADERS & DIVIDERS */
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30px;
  gap: 15px;
}

.section-header h2 {
  font-size: 28px;
  color: #2d3748;
  font-weight: 700;
  margin: 0;
}

.section-header h3 {
  font-size: 22px;
  color: #2d3748;
  font-weight: 600;
  margin: 0;
}

.section-subtitle {
  color: #718096;
  font-size: 14px;
  margin-bottom: 5px;
}

.section-divider {
  height: 1px;
  background: linear-gradient(90deg, transparent, #e2e8f0, transparent);
  margin: 40px 0;
}

/* BADGES */
.badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  padding: 6px 12px;
  border-radius: 20px;
  font-size: 12px;
  font-weight: 600;
}

.role-badge {
  display: inline-block;
  background: #f0f4f8;
  color: #667eea;
  padding: 4px 12px;
  border-radius: 12px;
  font-size: 12px;
  font-weight: 600;
}

/* QUICK ACTIONS */
.quick-actions {
  display: flex;
  gap: 10px;
}

.btn-small {
  padding: 8px 16px;
  font-size: 13px;
  border-radius: 8px;
  height: fit-content;
}

.btn-secondary {
  background: #f0f4f8;
  color: #667eea;
  border: 2px solid #667eea;
}

.btn-secondary:hover {
  background: #667eea;
  color: white;
}

.btn-lg {
  padding: 14px 32px;
  font-size: 16px;
}

/* FORM STYLING */
.form-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  gap: 16px;
  margin-bottom: 20px;
}

.form-group {
  display: flex;
  flex-direction: column;
}

/* ============ ENHANCED SECURITY STYLING ============ */

/* PASSWORD STRENGTH SECTION */
.password-strength-section {
  margin: 20px 0;
  padding: 15px;
  background: #f8f9fa;
  border-radius: 10px;
  border-left: 4px solid #667eea;
}

.password-strength-bar {
  width: 100%;
  height: 6px;
  background: #e2e8f0;
  border-radius: 3px;
  margin: 12px 0;
  overflow: hidden;
}

.strength-indicator {
  height: 100%;
  width: 0%;
  background: #cbd5e0;
  transition: all 0.3s ease;
  border-radius: 3px;
}

.strength-indicator.weak {
  width: 20%;
  background: #f56565;
}

.strength-indicator.fair {
  width: 40%;
  background: #ed8936;
}

.strength-indicator.good {
  width: 60%;
  background: #ecc94b;
}

.strength-indicator.strong {
  width: 80%;
  background: #48bb78;
}

.strength-indicator.very-strong {
  width: 100%;
  background: #38a169;
}

.strength-message {
  font-size: 12px;
  font-weight: 600;
  color: #718096;
  margin-bottom: 12px;
}

.password-requirements {
  margin-top: 12px;
  padding: 10px;
  background: white;
  border-radius: 6px;
  border: 1px solid #e2e8f0;
}

.password-requirements p {
  margin: 6px 0;
  font-size: 13px;
  display: flex;
  align-items: center;
}

.password-requirements strong {
  display: block;
  margin-bottom: 8px;
  font-size: 12px;
  color: #2d3748;
}

.requirement {
  color: #a0aec0;
  transition: all 0.3s ease;
}

.requirement.met {
  color: #38a169;
}

.requirement.met::before {
  content: "✓ ";
  color: #38a169;
  font-weight: 700;
}

.requirement.unmet::before {
  content: "✗ ";
  color: #f56565;
  font-weight: 700;
}

/* LOGIN INFO */
.login-info {
  margin: 15px 0;
  padding: 12px;
  background: #edf2f7;
  border-left: 4px solid #667eea;
  border-radius: 6px;
  font-size: 12px;
  color: #2d3748;
  line-height: 1.6;
}

/* ROLE INFO */
.role-info {
  padding: 12px;
  background: #f0fdf4;
  border-left: 4px solid #48bb78;
  border-radius: 6px;
  font-size: 12px;
  color: #166534;
  margin: 10px 0 !important;
}

/* SECURITY ALERT */
.security-alert {
  padding: 12px;
  background: #fef2f2;
  border: 1px solid #fca5a5;
  border-radius: 6px;
  color: #7f1d1d;
  font-size: 12px;
  margin-bottom: 15px;
  display: flex;
  align-items: center;
  gap: 8px;
}

.security-alert.success {
  background: #f0fdf4;
  border-color: #86efac;
  color: #166534;
}

.security-alert.warning {
  background: #fef3c7;
  border-color: #fde047;
  color: #92400e;
}

.security-alert.error {
  background: #fef2f2;
  border-color: #fca5a5;
  color: #7f1d1d;
}

/* ACCOUNT LOCKOUT DISPLAY */
.account-locked-message {
  padding: 15px;
  background: #fef2f2;
  border: 2px solid #f56565;
  border-radius: 8px;
  color: #7f1d1d;
  text-align: center;
  font-weight: 500;
  margin: 15px 0;
}
}

.form-group label {
  font-weight: 600;
  color: #2d3748;
  margin-bottom: 8px;
  font-size: 13px;
  text-transform: uppercase;
  letter-spacing: 0.5px;
}

/* CARD HEADER */
.card-header {
  margin-bottom: 20px;
  padding-bottom: 15px;
  border-bottom: 2px solid #f0f4f8;
}

.card-header h3 {
  margin: 0;
  color: #2d3748;
  font-size: 18px;
  font-weight: 600;
}

/* WELCOME HEADER */
.welcome-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 40px;
  padding: 20px;
  background: linear-gradient(135deg, #f7fafc 0%, #edf2f7 100%);
  border-radius: 12px;
  border-left: 4px solid #667eea;
}

.welcome-header h2 {
  margin: 0 0 8px 0;
  font-size: 26px;
  color: #2d3748;
}

.welcome-subtitle {
  color: #718096;
  margin: 0;
}

/* PROFILE STYLING */
.profile-header {
  display: flex;
  align-items: center;
  gap: 20px;
  margin-bottom: 25px;
  padding-bottom: 20px;
  border-bottom: 2px solid #f0f4f8;
}

.profile-avatar {
  font-size: 60px;
  width: 80px;
  height: 80px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 12px;
  color: white;
}

.profile-header h3 {
  margin: 0 0 5px 0;
  font-size: 24px;
  color: #2d3748;
  font-weight: 700;
}

.info-row {
  display: flex;
  justify-content: space-between;
  padding: 12px 0;
  border-bottom: 1px solid #f0f4f8;
  font-size: 15px;
}

.info-row:last-child {
  border-bottom: none;
}

.info-row .label {
  font-weight: 600;
  color: #667eea;
}

.info-row span:last-child {
  color: #2d3748;
}

/* STATS GRID COMPACT */
.stats-grid-compact {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
  gap: 20px;
  margin-top: 15px;
}

.stat-item {
  display: flex;
  flex-direction: column;
  padding: 15px;
  background: #f7fafc;
  border-radius: 10px;
  border-left: 3px solid #667eea;
}

.stat-label {
  font-size: 12px;
  color: #718096;
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  margin-bottom: 8px;
}

.stat-value {
  font-size: 24px;
  font-weight: 700;
  color: #667eea;
}

.stat-icon {
  font-size: 32px;
  margin-bottom: 10px;
}